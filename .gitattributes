# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Shell scripts must use LF
*.sh text eol=lf
*.init text eol=lf

# Lua files
*.lua text eol=lf

# Web files
*.htm text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Python files
*.py text eol=lf

# Markdown
*.md text eol=lf
